# --- W4DA worker configuration ---

# HTTP/WebSocket port the worker listens on.
PORT=8059

# Max players per room.
ROOM_CAPACITY=10

# Log filter (tracing EnvFilter syntax).
RUST_LOG=info,w4da_worker=info

# --- External database ---
# Option A: Laravel-style parts (the worker builds & URL-encodes the DSN).
DB_CONNECTION=mysql
DB_HOST=your-db-host
DB_PORT=3306
DB_DATABASE=survise_db
DB_USERNAME=your-user
DB_PASSWORD=your-password

# Option B: a full DSN (overrides the DB_* vars above). Leave empty to use A.
# DATABASE_URL=mysql://user:pass@host:3306/dbname
